-#!/bin/bash
-# Ralph Wiggum Loop - OpenCode Edition (Improved with safeguards)
-# Usage: ./ralph/ralph_improved.sh [max_iterations]
-
-set -e
-
-# --- CONFIGURATION ---
-MAX_ITERATIONS=${1:-200}
-MODEL="openai/gpt-5.2-codex"
-ITERATION_TIMEOUT=1800  # 30 minutes per iteration
