-                fixture_entry = fixtures.setdefault(
-                    str(action.fixture_id), {"odds": {}, "outcome": None}
-                )
-                if isinstance(fixture_entry, dict):
-                    fixture_entry["outcome"] = outcomes[index]
-
-        if not fixtures:
