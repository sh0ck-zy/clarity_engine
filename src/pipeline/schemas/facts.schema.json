{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clarity.local/schemas/facts.schema.json",
  "title": "Clarity Analysis Facts",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fixture",
    "inputs",
    "derived",
    "ml",
    "validation_checks",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_id",
        "competition",
        "season",
        "round_number",
        "match_date",
        "home_team",
        "away_team"
      ],
      "properties": {
        "fixture_id": { "type": "string" },
        "competition": { "type": "string" },
        "season": { "type": "string" },
        "round_number": { "type": "integer", "minimum": 1 },
        "match_date": { "type": "string", "format": "date-time" },
        "home_team": { "type": "string" },
        "away_team": { "type": "string" }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deterministic", "non_deterministic", "unavailable"],
      "properties": {
        "deterministic": {
          "type": "object",
          "additionalProperties": false,
          "required": ["team_states", "h2h", "key_players", "injuries"],
          "properties": {
            "team_states": {
              "type": "object",
              "additionalProperties": false,
              "required": ["snapshot_round", "home", "away"],
              "properties": {
                "snapshot_round": { "type": "integer", "minimum": 0 },
                "home": { "type": "object" },
                "away": { "type": "object" }
              }
            },
            "h2h": {
              "type": ["object", "null"]
            },
            "key_players": {
              "type": ["object", "null"]
            },
            "injuries": {
              "type": ["object", "null"]
            }
          }
        },
        "non_deterministic": {
          "type": "object",
          "additionalProperties": false,
          "required": ["elo", "odds"],
          "properties": {
            "elo": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "required": ["pre_match_elo_date", "home", "away", "source", "cache_hit"],
              "properties": {
                "pre_match_elo_date": { "type": "string", "format": "date" },
                "home": { "type": ["number", "null"] },
                "away": { "type": ["number", "null"] },
                "source": { "type": ["string", "null"] },
                "cache_hit": { "type": ["boolean", "null"] }
              }
            },
            "odds": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "required": ["bookmaker", "home", "draw", "away", "implied_probs_norm"],
              "properties": {
                "bookmaker": { "type": ["string", "null"] },
                "home": { "type": ["number", "null"] },
                "draw": { "type": ["number", "null"] },
                "away": { "type": ["number", "null"] },
                "implied_probs_norm": {
                  "type": ["object", "null"],
                  "additionalProperties": false,
                  "required": ["home", "draw", "away"],
                  "properties": {
                    "home": { "type": ["number", "null"] },
                    "draw": { "type": ["number", "null"] },
                    "away": { "type": ["number", "null"] }
                  }
                }
              }
            }
          }
        },
        "unavailable": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "reason"],
            "properties": {
              "field": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "derived": {
      "type": "object",
      "additionalProperties": false,
      "required": ["features", "scaling"],
      "properties": {
        "features": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "value", "source"],
            "properties": {
              "name": { "type": "string" },
              "value": { "type": ["number", "null"] },
              "source": { "type": "string" }
            }
          }
        },
        "scaling": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["feature", "mean", "scale", "scaled_value"],
            "properties": {
              "feature": { "type": "string" },
              "mean": { "type": "number" },
              "scale": { "type": "number" },
              "scaled_value": { "type": ["number", "null"] }
            }
          }
        }
      }
    },
    "ml": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "probabilities",
        "prediction",
        "signals",
        "drivers",
        "risk_flags",
        "training_context"
      ],
      "properties": {
        "model": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "feature_subset", "C", "random_state"],
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" },
            "feature_subset": { "type": "string" },
            "C": { "type": "number" },
            "random_state": { "type": ["integer", "null"] }
          }
        },
        "probabilities": {
          "type": "object",
          "additionalProperties": false,
          "required": ["home_win", "draw", "away_win"],
          "properties": {
            "home_win": { "type": "number", "minimum": 0, "maximum": 1 },
            "draw": { "type": "number", "minimum": 0, "maximum": 1 },
            "away_win": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "prediction": {
          "type": "object",
          "additionalProperties": false,
          "required": ["predicted_result", "confidence_label"],
          "properties": {
            "predicted_result": { "type": "string", "enum": ["H", "D", "A"] },
            "confidence_label": { "type": "string", "enum": ["high", "medium", "low"] }
          }
        },
        "signals": {
          "type": "object",
          "additionalProperties": false,
          "required": ["p_max", "margin_top2", "entropy_norm"],
          "properties": {
            "p_max": { "type": "number", "minimum": 0, "maximum": 1 },
            "margin_top2": { "type": "number", "minimum": 0, "maximum": 1 },
            "entropy_norm": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "drivers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["feature", "value", "contribution", "direction"],
            "properties": {
              "feature": { "type": "string" },
              "value": { "type": ["number", "null"] },
              "contribution": { "type": "number" },
              "direction": { "type": "string", "enum": ["home", "draw", "away", "mixed"] }
            }
          }
        },
        "risk_flags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "training_context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["train_size", "train_rounds"],
          "properties": {
            "train_size": { "type": "integer", "minimum": 1 },
            "train_rounds": {
              "type": "array",
              "items": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "validation_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "warn", "fail"] },
          "details": { "type": ["string", "null"] }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "created_at",
        "facts_hash",
        "data_snapshot_round",
        "deterministic_sources",
        "non_deterministic_sources"
      ],
      "properties": {
        "run_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "facts_hash": { "type": "string" },
        "data_snapshot_round": { "type": "integer", "minimum": 0 },
        "deterministic_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "non_deterministic_sources": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
