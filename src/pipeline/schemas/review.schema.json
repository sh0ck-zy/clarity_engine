{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clarity.local/schemas/review.schema.json",
  "title": "Clarity Human Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "status",
    "reviewed_at",
    "reviewer",
    "notes",
    "hashes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": { "type": "string" },
    "status": { "type": "string", "enum": ["approved", "rejected", "needs_changes"] },
    "reviewed_at": { "type": "string", "format": "date-time" },
    "reviewer": { "type": "string" },
    "notes": { "type": "string" },
    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["facts_hash", "report_hash"],
      "properties": {
        "facts_hash": { "type": "string" },
        "report_hash": { "type": "string" }
      }
    }
  }
}
